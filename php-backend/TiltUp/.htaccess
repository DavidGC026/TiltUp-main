<IfModule mod_php.c>
    php_value upload_max_filesize 20M
    php_value post_max_size 20M
    php_value max_execution_time 120
    php_value max_input_time 120
    php_flag file_uploads On
</IfModule>

<IfModule mod_fcgid.c>
    FcgidMaxRequestLen 20971520
</IfModule>

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /TiltUp/
    
    # 1. API Requests -> index.php (handling /api prefix if needed or just letting index.php router handle it)
    RewriteCond %{REQUEST_URI} ^/TiltUp/api/ [NC]
    RewriteRule ^(.*)$ index.php [QSA,L]

    # 2. Real files/directories -> Serve directly
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # 3. Everything else -> index.html (SPA Routing)
    RewriteRule ^ index.html [L]
</IfModule>
